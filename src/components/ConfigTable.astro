---
import gameManifest from '../data/game-manifest.json';

const { title = 'LIVE CONFIGURATION', rows = [] } = Astro.props;
const read = (path) => path.split('.').reduce((value, key) => value?.[key], gameManifest.config);
const format = (value, row) => {
  if (value == null) return '—';
  if (row.format === 'percent') return `${Math.round(value * 100)}%`;
  if (row.format === 'multiplier') return `${value}×`;
  const rounded = typeof value === 'number' ? Math.round(value * 1000) / 1000 : value;
  return `${rounded}${row.unit ? ` ${row.unit}` : ''}`;
};
---

<section class="config-table" aria-label={title}>
  <header><span>{title}</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header>
  <dl>
    {rows.map((row) => <div><dt>{row.label}<small>{row.path}</small></dt><dd>{format(read(row.path), row)}</dd>{row.note && <p>{row.note}</p>}</div>)}
  </dl>
</section>

<style>
  .config-table { border: 1px solid var(--sl-color-hairline); font-family: var(--sl-font-mono); margin: 1.5rem 0; }
  header { background: var(--sl-color-gray-6); border-bottom: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-3); display: flex; font-size: .65rem; font-weight: 800; justify-content: space-between; letter-spacing: .1em; padding: .65rem .75rem; text-transform: uppercase; }
  code { color: var(--tear-cyan); font: inherit; } dl { margin: 0; } dl > div { align-items: center; border-bottom: 1px solid var(--sl-color-hairline); display: grid; gap: .7rem; grid-template-columns: minmax(0, 1fr) auto; padding: .6rem .75rem; } dl > div:last-child { border-bottom: 0; }
  dt { color: var(--sl-color-gray-2); font-size: .76rem; text-transform: uppercase; } dt small { color: var(--sl-color-gray-3); display: block; font-size: .61rem; letter-spacing: .04em; margin-top: .2rem; text-transform: none; } dd { color: var(--sl-color-white); font-size: .9rem; font-weight: 800; margin: 0; } p { color: var(--sl-color-gray-3); font-family: var(--sl-font); font-size: .7rem; grid-column: 1 / -1; line-height: 1.4; margin: -.2rem 0 0; }
</style>
