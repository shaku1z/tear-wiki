---
import { CONFIG } from '../scripts/game-engine.js';

const { path } = Astro.props;
const value = path.split('.').reduce((acc, part) => acc && acc[part], CONFIG);
---

<span class="config-value">{value}</span>

<style>
  .config-value {
    color: var(--theme-accent, #13c4d6);
    font-weight: bold;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    background: rgba(19, 196, 214, 0.1);
    padding: 0.1em 0.3em;
    border-radius: 4px;
    border: 1px solid rgba(19, 196, 214, 0.3);
  }
</style>
