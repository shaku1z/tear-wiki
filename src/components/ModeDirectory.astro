---
import gameManifest from '../data/game-manifest.json';
const links = { campaign:'/modes/adventure', endless:'/modes/endless', gauntlet:'/modes/gauntlet', playground:'/modes/playground' };
---
<section class="mode-directory"><header><span>MODE DIRECTORY</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header><div>{gameManifest.config.modes.filter((mode) => mode.enabled).map((mode) => <a href={links[mode.id] || '#'}><b>{mode.label}</b><span>{mode.blurb}</span><em>{mode.training ? 'TRAINING' : mode.bossOnly ? 'BOSS PROTOCOL' : mode.sandbox ? 'SANDBOX' : 'RUN MODE'}</em></a>)}</div></section>
<style>.mode-directory{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.mode-directory>div{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr))}.mode-directory a{border-bottom:1px solid var(--sl-color-hairline);border-right:1px solid var(--sl-color-hairline);color:inherit;padding:.8rem;text-decoration:none}.mode-directory a:hover{background:var(--sl-color-gray-6)}a b,a span,a em{display:block}a b{font-size:.8rem;letter-spacing:.08em;text-transform:uppercase}a span{color:var(--sl-color-gray-3);font-family:var(--sl-font);font-size:.75rem;line-height:1.45;margin-top:.35rem}a em{color:var(--tear-cyan);font-size:.6rem;font-style:normal;font-weight:800;letter-spacing:.08em;margin-top:.65rem}</style>
