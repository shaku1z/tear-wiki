---
import { STAGES } from '../scripts/game-engine.js';
import gameManifest from '../data/game-manifest.json';
const { id } = Astro.props;
const stage = typeof id === 'number' ? STAGES[id] : STAGES.find((entry) => entry.name.toLowerCase().includes(id.toLowerCase()));
---

{stage ? <section class="stage-terminal" style={`--stage-accent:${stage.accent};--stage-bg:${stage.bg}`}>
  <header><div><span>STAGE DOSSIER / LIVE POOL</span><h2>{stage.name}</h2><p>{stage.blurb}</p></div><code>{gameManifest.source.commit.slice(0, 7)}</code></header>
  <div class="stage-grid"><div><h3>ENEMY DEPLOYMENT</h3><ul>{stage.pool.map(([type, weight, minWave]) => <li><b>{type}</b><span>WEIGHT {weight} / WAVE {minWave}</span></li>)}</ul></div><div class="stage-side"><blockquote>{stage.lore}</blockquote><div class="stage-meta"><span>BOSS <b>{stage.boss}</b></span><span>PLATFORM <i style={`background:${stage.plat}`}></i></span></div></div></div>
</section> : <p>Stage not found: {id}</p>}

<style>
.stage-terminal { border:1px solid var(--sl-color-hairline); border-top:4px solid var(--stage-accent); font-family:var(--sl-font-mono); margin:1.5rem 0; } header { background:var(--stage-bg); color:#111; display:flex; justify-content:space-between; padding:1rem; } header span,h3 { font-size:.64rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; } h2 { border:0; color:inherit; margin:.35rem 0; padding:0; } header p { margin:0; font-family:var(--sl-font); } code { font:inherit; font-size:.65rem; } .stage-grid { display:grid; grid-template-columns:1fr 1fr; } .stage-grid>div { padding:1rem; } .stage-grid>div+div { border-left:1px solid var(--sl-color-hairline); } h3 { color:var(--sl-color-gray-3); margin:0 0 .6rem; } ul { list-style:none; margin:0; padding:0; } li { border-top:1px solid var(--sl-color-hairline); display:flex; justify-content:space-between; padding:.55rem 0; text-transform:uppercase; } li span { color:var(--sl-color-gray-3); font-size:.65rem; } blockquote { border-left:3px solid var(--stage-accent); color:var(--sl-color-gray-2); font-family:var(--sl-font); margin:0; padding-left:.75rem; } .stage-meta { display:flex; gap:1rem; margin-top:1rem; } .stage-meta span { color:var(--sl-color-gray-3); font-size:.65rem; } .stage-meta b { color:var(--sl-color-white); display:block; margin-top:.3rem; } i { border:1px solid var(--sl-color-hairline); display:block; height:1rem; margin-top:.3rem; width:2rem; } @media(max-width:600px){.stage-grid{grid-template-columns:1fr}.stage-grid>div+div{border-left:0;border-top:1px solid var(--sl-color-hairline)}}
</style>
