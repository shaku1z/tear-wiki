---
import gameManifest from '../data/game-manifest.json';
const run = gameManifest.config.run;
const rows = [['HP per wave', run.hpScalePerWave, 'percent'], ['Damage per stage', run.stageDmgStep, 'percent'], ['Damage per wave', run.inStageDmg, 'percent'], ['HP per stage', run.stageHpStep, 'percent'], ['Enemy count per wave', run.countPerWave, 'number'], ['Stage count increase', run.stageCountStep, 'number'], ['Concurrent cap', run.maxConcurrentCap, 'number'], ['Wave-clear healing', run.healEachWave, 'number']];
const fmt = (value, type) => type === 'percent' ? `${Math.round(value * 100)}%` : value;
---
<section class="run-readout"><header><span>RUN PACING / LIVE CONFIGURATION</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header><div>{rows.map(([label, value, type]) => <p><span>{label}</span><b>{fmt(value, type)}</b></p>)}</div></section>
<style>.run-readout{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.run-readout>div{display:grid;grid-template-columns:1fr 1fr}.run-readout p{border-bottom:1px solid var(--sl-color-hairline);display:flex;justify-content:space-between;margin:0;padding:.6rem .75rem}.run-readout p:nth-child(odd){border-right:1px solid var(--sl-color-hairline)}.run-readout span{color:var(--sl-color-gray-3);font-size:.7rem;text-transform:uppercase}.run-readout b{color:var(--sl-color-white)}@media(max-width:540px){.run-readout>div{grid-template-columns:1fr}.run-readout p:nth-child(odd){border-right:0}}</style>
