---
import gameManifest from '../data/game-manifest.json';
import TierPath from './TierPath.astro';

const { category } = Astro.props;
const filtered = category === 'stackable'
  ? gameManifest.upgrades.filter((upgrade) => !upgrade.unique && upgrade.tiers.length === 0)
  : category
    ? gameManifest.upgrades.filter((upgrade) => upgrade.cat === category)
    : gameManifest.upgrades;

const labels = { offense: 'OFFENSE', resilience: 'RESILIENCE', mobility: 'MOBILITY', throw: 'THROW', parry: 'PARRY', utility: 'UTILITY' };
---

<section class="upgrade-catalogue" aria-label="Game-synchronized upgrades">
  <div class="catalogue-signal">
    <span>LIVE UPGRADE INDEX</span>
    <span>{filtered.length} MODULES</span>
    <code>{gameManifest.source.commit.slice(0, 7)}</code>
  </div>
  <div class="upgrades-grid">
    {filtered.map((upgrade) => (
      <div role="article" data-wiki-card class:list={['upgrade-module', `cat-${upgrade.cat}`, upgrade.rare && 'rare']}>
        <header>
          <span class="module-type">{upgrade.tiers.length ? 'SPECIAL' : upgrade.unique ? 'UNIQUE' : 'STACKS'}</span>
          <span class="module-domain">{labels[upgrade.cat] || upgrade.cat}</span>
        </header>
        <h3>{upgrade.name}</h3>
        <p>{upgrade.desc}</p>
        {upgrade.progression === 'tiered' && <TierPath upgrade={upgrade} />}
      </div>
    ))}
  </div>
</section>

<style>
  .upgrade-catalogue { --cyan: #13c4d6; --red: #e23b3b; --blue: #2f6df0; --purple: #8b3bd6; --orange: #ef8a17; --green: #1faf5a; --gold: #e0a326; margin: 1.5rem 0; }
  .catalogue-signal { border: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-3); display: flex; font-family: var(--sl-font-mono); font-size: .65rem; font-weight: 800; gap: 1rem; letter-spacing: .1em; padding: .55rem .7rem; text-transform: uppercase; }
  .catalogue-signal code { color: var(--cyan); font: inherit; margin-left: auto; }
  .upgrades-grid { align-items: stretch; display: grid; gap: .6rem; grid-template-columns: repeat(auto-fill, minmax(225px, 1fr)); margin-top: .6rem; }
  .upgrades-grid > [data-wiki-card] { align-self: stretch; margin: 0; }
  .upgrade-module { --accent: var(--cyan); background: var(--sl-color-bg); border: 1px solid var(--sl-color-hairline); border-left: 4px solid var(--accent); display: flex; flex-direction: column; min-height: 13.5rem; padding: .85rem; }
  .upgrade-module:hover { background: var(--sl-color-gray-6); border-color: var(--accent); }
  .upgrade-module header { display: flex; justify-content: space-between; }
  .module-type, .module-domain { color: var(--sl-color-gray-3); font-family: var(--sl-font-mono); font-size: .62rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .module-domain { color: var(--accent); }
  .upgrade-module h3 { border: 0; color: var(--sl-color-white); font-size: .95rem; letter-spacing: .06em; margin: .65rem 0 .4rem; padding: 0; }
  .upgrade-module p { color: var(--sl-color-gray-2); font-size: .82rem; line-height: 1.5; margin: 0; }
  .cat-offense { --accent: var(--red); } .cat-resilience { --accent: var(--green); } .cat-mobility { --accent: var(--blue); } .cat-throw { --accent: var(--orange); } .cat-parry { --accent: var(--cyan); } .cat-utility { --accent: var(--purple); } .rare { --accent: var(--gold); }
  @media (max-width: 560px) { .upgrades-grid { grid-template-columns: 1fr; } .catalogue-signal { flex-wrap: wrap; } .catalogue-signal code { margin-left: 0; } }
</style>
