---
import { UPGRADES } from '../scripts/game-engine.js';
const { category } = Astro.props;

const filtered = category 
  ? UPGRADES.filter(u => u.cat === category)
  : UPGRADES;
---

<div class="upgrades-grid">
  {filtered.map(upg => {
    return (
      <div class={`upgrade-card cat-${upg.cat}`}>
        <div class="card-header">
          <h4>{upg.name}</h4>
          {upg.unique && <span class="badge">Unique</span>}
        </div>
        <p>{upg.desc}</p>
      </div>
    );
  })}
</div>

<style>
  .upgrades-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: clamp(12px, 3vw, 24px);
    margin: 30px 0;
    font-family: system-ui, -apple-system, sans-serif;
  }
  
  @media (min-width: 640px) {
    .upgrades-grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media (min-width: 1024px) {
    .upgrades-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .upgrade-card {
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    padding: clamp(16px, 4vw, 24px);
    color: var(--sl-color-text);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    position: relative;
    overflow: hidden;
  }

  .upgrade-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    border-color: var(--sl-color-accent);
  }

  .upgrade-card:active {
    transform: scale(0.98);
  }

  .cat-offense { border-top: 3px solid #ef4444; }
  .cat-resilience { border-top: 3px solid #10b981; }
  .cat-mobility { border-top: 3px solid #3b82f6; }
  .cat-utility { border-top: 3px solid #a855f7; }
  .cat-throw { border-top: 3px solid #f59e0b; }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .card-header h4 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.2;
  }

  .badge {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border: 1px solid var(--sl-color-accent);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .upgrade-card p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }
</style>
