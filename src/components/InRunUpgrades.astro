---
import { UPGRADES } from '../scripts/game-engine.js';
const { category } = Astro.props;

const filtered = category 
  ? UPGRADES.filter(u => u.cat === category)
  : UPGRADES;
---

<div class="upgrades-grid">
  {filtered.map(upg => {
    return (
      <div class={`upgrade-card cat-${upg.cat}`}>
        <div class="card-header">
          <h4>{upg.name}</h4>
          {upg.unique && <span class="badge">Unique</span>}
        </div>
        <p>{upg.desc}</p>
      </div>
    );
  })}
</div>

<style>
  .upgrades-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 20px;
    margin: 30px 0;
    font-family: system-ui, -apple-system, sans-serif;
  }
  
  @media (min-width: 640px) {
    .upgrades-grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media (min-width: 1024px) {
    .upgrades-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .upgrade-card {
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 12px;
    padding: 20px;
    color: var(--sl-color-text);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }
  
  .upgrade-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    opacity: 0.05;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .upgrade-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    border-color: var(--sl-color-accent);
  }

  .upgrade-card:hover::before {
    opacity: 0.15;
  }

  .cat-offense::before { background: linear-gradient(135deg, #ef4444, transparent); }
  .cat-resilience::before { background: linear-gradient(135deg, #10b981, transparent); }
  .cat-mobility::before { background: linear-gradient(135deg, #3b82f6, transparent); }
  .cat-utility::before { background: linear-gradient(135deg, #a855f7, transparent); }
  .cat-throw::before { background: linear-gradient(135deg, #f59e0b, transparent); }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .card-header h4 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1.2;
  }

  .badge {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border: 1px solid var(--sl-color-accent);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .upgrade-card p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }
</style>
