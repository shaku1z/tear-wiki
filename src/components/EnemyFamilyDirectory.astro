---
import gameManifest from '../data/game-manifest.json';
const families = ['charger','ranged','flyer','bomber','armored','support','wraith','chimera'];
---
<section class="family-directory"><header><span>ENEMY FAMILY DIRECTORY</span><code>{gameManifest.source.commit.slice(0,7)}</code></header><div>{families.filter((id)=>gameManifest.config[id]).map((id)=><a href={`/enemies/${id}`}><b>{id}</b><span>HP {gameManifest.config[id].hp} / SPD {gameManifest.config[id].speed} / DMG {gameManifest.config[id].contactDmg}</span></a>)}</div></section>
<style>.family-directory{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.family-directory>div{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr))}.family-directory a{border-bottom:1px solid var(--sl-color-hairline);border-right:1px solid var(--sl-color-hairline);color:inherit;padding:.7rem;text-decoration:none}.family-directory a:hover{background:var(--sl-color-gray-6)}a b{display:block;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase}a span{color:var(--sl-color-gray-3);display:block;font-size:.65rem;margin-top:.35rem}</style>
