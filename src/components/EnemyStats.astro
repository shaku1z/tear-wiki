---
import { CONFIG, VARIANTS } from '../scripts/game-engine.js';
import gameManifest from '../data/game-manifest.json';

const { variant } = Astro.props;
let foundVariant = null;
let baseEnemyType = null;

for (const [type, list] of Object.entries(VARIANTS)) {
  const match = list.find((entry) => entry.id === variant);
  if (match) {
    foundVariant = match;
    baseEnemyType = type;
    break;
  }
}

if (!foundVariant && CONFIG[variant]) baseEnemyType = variant;
const baseConfig = CONFIG[baseEnemyType] || {};
const stats = { hp: baseConfig.hp || 0, maxHp: baseConfig.hp || 0, speedMult: 1, speed: baseConfig.speed || 0, contactDmg: baseConfig.contactDmg || 0 };
if (foundVariant?.apply) foundVariant.apply(stats);

const label = foundVariant?.name || (variant.charAt(0).toUpperCase() + variant.slice(1));
const accent = CONFIG.colors[baseEnemyType] || CONFIG.colors.enemyShot;
const metrics = [
  ['BASE HP', Math.round(stats.maxHp)],
  ['MOVE SPEED', Math.round(stats.speed * stats.speedMult)],
  ['CONTACT DMG', Math.round(stats.contactDmg)],
  ['WEIGHT', baseConfig.weight ?? '—'],
];
---

<section class="enemy-terminal" style={`--entity-accent: ${accent}`} aria-label={`${label} statistics`}>
  <header>
    <div><span>ENTITY READOUT / {baseEnemyType || 'UNKNOWN'}</span><h3>{label}</h3></div>
    <code>{gameManifest.source.commit.slice(0, 7)}</code>
  </header>
  <div class="metric-grid">
    {metrics.map(([name, value]) => <div class="metric"><span>{name}</span><strong>{value}</strong></div>)}
  </div>
  {foundVariant && <p class="variant-note">VARIANT MODULE ACTIVE — source modifiers are applied to the base entity before display.</p>}
</section>

<style>
  .enemy-terminal { border: 1px solid var(--sl-color-hairline); border-left: 4px solid var(--entity-accent); font-family: var(--sl-font-mono); margin: 1.5rem 0; }
  header { align-items: start; background: var(--sl-color-gray-6); border-bottom: 1px solid var(--sl-color-hairline); display: flex; justify-content: space-between; padding: .8rem .9rem; }
  header span { color: var(--sl-color-gray-3); display: block; font-size: .62rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  h3 { border: 0; font-size: 1.15rem; letter-spacing: .08em; margin: .4rem 0 0; padding: 0; } code { color: var(--entity-accent); font: inherit; font-size: .65rem; }
  .metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .metric { border-right: 1px solid var(--sl-color-hairline); padding: .75rem .85rem; } .metric:last-child { border-right: 0; }
  .metric span { color: var(--sl-color-gray-3); display: block; font-size: .6rem; font-weight: 800; letter-spacing: .08em; } .metric strong { color: var(--sl-color-white); display: block; font-size: 1.15rem; margin-top: .35rem; }
  .variant-note { border-top: 1px dashed var(--sl-color-hairline); color: var(--sl-color-gray-3); font-family: var(--sl-font); font-size: .75rem; margin: 0; padding: .65rem .85rem; }
  @media (max-width: 560px) { .metric-grid { grid-template-columns: 1fr 1fr; } .metric:nth-child(2) { border-right: 0; } .metric:nth-child(-n+2) { border-bottom: 1px solid var(--sl-color-hairline); } }
</style>
