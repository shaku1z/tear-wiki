---
import gameManifest from '../data/game-manifest.json';
const labels = { tank: 'TANK', swift: 'SWIFT', rapid: 'RAPID', volley: 'VOLLEY', armed: 'ARMED', warded: 'WARDED' };
const summaries = { tank: 'Durability and launch resistance.', swift: 'Movement acceleration.', rapid: 'Faster projectile cadence.', volley: 'Multi-projectile bursts.', armed: 'Expanded melee pressure.', warded: 'Independent shield layer.' };
---
<section class="affix-catalogue"><header><span>AFFIX + ELITE ARCHIVE</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header><div class="affixes">{gameManifest.affixes.list.map((affix) => <article style={`--affix:${affix.color}`}><i></i><h3>{labels[affix.id] || affix.id}</h3><p>{summaries[affix.id] || 'Live enemy modifier.'}</p></article>)}</div><div class="presets"><h2>AUTHORED PRESETS</h2>{gameManifest.affixes.presets.map((preset) => <p><b>{preset.type}</b><span>{preset.affixes.join(' + ')}</span></p>)}</div></section>
<style>.affix-catalogue{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.affixes{align-items:stretch;display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr))}.affixes article{border-bottom:1px solid var(--sl-color-hairline);border-right:1px solid var(--sl-color-hairline);margin:0;padding:.75rem}.affixes i{background:var(--affix);display:block;height:.3rem;margin-bottom:.65rem}.affixes h3{border:0;font-size:.8rem;margin:0;padding:0}.affixes p{color:var(--sl-color-gray-3);font-family:var(--sl-font);font-size:.72rem;line-height:1.4;margin:.4rem 0 0}.presets{padding:.9rem}.presets h2{border:0;color:var(--sl-color-gray-3);font-size:.68rem;margin:0 0 .5rem;padding:0}.presets p{border-top:1px solid var(--sl-color-hairline);display:flex;justify-content:space-between;margin:0;padding:.5rem 0;text-transform:uppercase}.presets span{color:var(--tear-cyan);font-size:.68rem}</style>
