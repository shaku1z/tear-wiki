---
import { CONFIG } from '../scripts/game-engine.js';
import gameManifest from '../data/game-manifest.json';

const { name } = Astro.props;
const bossConfig = CONFIG[name.toLowerCase()] || CONFIG.boss;
const hiddenKeys = new Set(['w', 'h', 'hp', 'speed', 'contactDmg', 'weight', 'knockbackTaken']);
const mechanics = Object.entries(bossConfig).filter(([key, value]) => !hiddenKeys.has(key) && typeof value !== 'object');
const metrics = [['BASE HP', bossConfig.hp], ['MOVE SPEED', bossConfig.speed], ['CONTACT DMG', bossConfig.contactDmg], ['WEIGHT', bossConfig.weight]];
---

<section class="boss-terminal" aria-label={`${name} boss data`}>
  <header>
    <div><span>BOSS DOSSIER / LIVE CONFIGURATION</span><h2>{name}</h2></div>
    <code>{gameManifest.source.commit.slice(0, 7)}</code>
  </header>
  <div class="boss-metrics">
    {metrics.map(([label, value]) => <div><span>{label}</span><strong>{value}</strong></div>)}
  </div>
  <div class="mechanics">
    <h3>MECHANICAL PARAMETERS</h3>
    <dl>
      {mechanics.map(([key, value]) => <div><dt>{key.replace(/([A-Z])/g, ' $1')}</dt><dd>{typeof value === 'number' ? Math.round(value * 100) / 100 : String(value)}</dd></div>)}
    </dl>
  </div>
</section>

<style>
  .boss-terminal { --boss: var(--tear-red); border: 2px solid var(--sl-color-white); border-top: 4px solid var(--boss); font-family: var(--sl-font-mono); margin: 1.5rem 0; }
  header { align-items: start; background: var(--sl-color-gray-6); border-bottom: 1px solid var(--sl-color-hairline); display: flex; justify-content: space-between; padding: 1rem; }
  header span, h3 { color: var(--sl-color-gray-3); display: block; font-size: .63rem; font-weight: 800; letter-spacing: .11em; text-transform: uppercase; }
  h2 { border: 0; font-size: clamp(1.35rem, 4vw, 2rem); letter-spacing: .1em; margin: .4rem 0 0; padding: 0; } code { color: var(--boss); font: inherit; font-size: .65rem; }
  .boss-metrics { display: grid; grid-template-columns: repeat(4, 1fr); } .boss-metrics > div { border-right: 1px solid var(--sl-color-hairline); margin: 0; min-width: 0; padding: .9rem; } .boss-metrics > div:last-child { border-right: 0; }
  .boss-metrics span { color: var(--sl-color-gray-3); display: block; font-size: .6rem; font-weight: 800; letter-spacing: .08em; } .boss-metrics strong { color: var(--sl-color-white); display: block; font-size: 1.35rem; margin-top: .35rem; }
  .mechanics { border-top: 1px solid var(--sl-color-hairline); padding: 1rem; } .mechanics h3 { border: 0; margin: 0 0 .7rem; padding: 0; }
  dl { border: 1px solid var(--sl-color-hairline); margin: 0; } dl div { border-bottom: 1px solid var(--sl-color-hairline); display: grid; grid-template-columns: 1fr auto; gap: 1rem; margin: 0; min-width: 0; padding: .55rem .65rem; } dl div:last-child { border-bottom: 0; } dt { color: var(--sl-color-gray-2); font-size: .72rem; text-transform: uppercase; } dd { color: var(--boss); font-size: .78rem; font-weight: 800; margin: 0; }
  @media (max-width: 560px) { .boss-metrics { grid-template-columns: 1fr 1fr; } .boss-metrics > div:nth-child(2) { border-right: 0; } .boss-metrics > div:nth-child(-n+2) { border-bottom: 1px solid var(--sl-color-hairline); } }
</style>
