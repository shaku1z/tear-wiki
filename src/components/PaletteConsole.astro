---
import gameManifest from '../data/game-manifest.json';

const colors = Object.entries(gameManifest.config.colors ?? {});
const label = (key) => key.replace(/([A-Z])/g, ' $1').replace(/^./, (character) => character.toUpperCase());
---

<section class="palette-console" aria-label="Live game colour palette">
  <header>
    <span>LIVE PALETTE / CONFIG.COLORS</span>
    <code>{gameManifest.source.commit.slice(0, 7)}</code>
  </header>
  <div class="palette-grid">
    {colors.map(([key, value]) => (
      <article>
        <span class="swatch" style={`--swatch:${value}`}></span>
        <div><strong>{label(key)}</strong><small>{key}</small></div>
        <code>{value}</code>
      </article>
    ))}
  </div>
</section>

<style>
  .palette-console { border: 1px solid var(--sl-color-hairline); margin: 1.5rem 0; }
  header { align-items: center; background: var(--sl-color-gray-6); border-bottom: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-3); display: flex; font-family: var(--sl-font-mono); font-size: .65rem; font-weight: 800; justify-content: space-between; letter-spacing: .1em; padding: .65rem .75rem; text-transform: uppercase; }
  header code, article > code { color: var(--tear-cyan); font: inherit; }
  .palette-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); }
  article { align-items: center; border-bottom: 1px solid var(--sl-color-hairline); border-right: 1px solid var(--sl-color-hairline); display: grid; gap: .6rem; grid-template-columns: 1.35rem 1fr auto; min-height: 3.25rem; padding: .55rem .65rem; }
  .swatch { background: var(--swatch); box-shadow: 0 0 12px color-mix(in srgb, var(--swatch), transparent 35%); display: block; height: 1.25rem; outline: 1px solid var(--sl-color-white); outline-offset: 2px; width: 1.25rem; }
  strong { color: var(--sl-color-white); display: block; font-family: var(--sl-font-mono); font-size: .7rem; letter-spacing: .04em; text-transform: uppercase; }
  small { color: var(--sl-color-gray-3); display: block; font-family: var(--sl-font-mono); font-size: .58rem; margin-top: .12rem; }
  article > code { font-size: .62rem; }
</style>
