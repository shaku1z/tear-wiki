---
// Light is the canonical 2D field composition; dark is its polarity-matched counterpart.
---

<section class="blade-field" aria-labelledby="blade-field-title">
  <div class="blade-field__art" aria-hidden="true">
    <img class="blade-field__image blade-field__image--light" src="/brand/tear-blade-field-light.png" alt="" />
    <img class="blade-field__image blade-field__image--dark" src="/brand/tear-blade-field-dark.png" alt="" />
  </div>
  <div class="blade-field__scrim" aria-hidden="true"></div>
  <div class="blade-field__content">
    <p class="blade-field__eyebrow"><span></span> Official field manual</p>
    <h1 id="blade-field-title"><small>TEAR</small><strong>BLADE</strong></h1>
    <p class="blade-field__lede">A living reference for a precision action game: systems, enemies, abilities, and the decisions between the cuts.</p>
    <div class="blade-field__actions">
      <a href="/builder" class="blade-field__primary">Open Ability Lab <span aria-hidden="true">→</span></a>
      <a href="/getting-started/overview" class="blade-field__secondary">Read combat primer</a>
    </div>
    <dl class="blade-field__legend" aria-label="Tear combat language">
      <div><dt class="red">01</dt><dd>Read</dd></div><div><dt class="cyan">02</dt><dd>Commit</dd></div><div><dt class="violet">03</dt><dd>Adapt</dd></div>
    </dl>
  </div>
</section>

<style>
  .blade-field { isolation:isolate; min-height:min(720px,calc(100vh - 4rem)); overflow:hidden; position:relative; display:grid; place-items:center; border-bottom:1px solid var(--sl-color-hairline); background:var(--sl-color-bg); }
  .blade-field__art,.blade-field__image,.blade-field__scrim { inset:0; position:absolute; width:100%; height:100%; }
  .blade-field__image { display:block; object-fit:cover; object-position:center; }
  .blade-field__image--dark { opacity:0; }
  :global(:root[data-theme='dark']) .blade-field__image--light { opacity:0; }
  :global(:root[data-theme='dark']) .blade-field__image--dark { opacity:1; }
  .blade-field__scrim { background:linear-gradient(90deg,color-mix(in srgb,var(--sl-color-bg) 86%,transparent) 0%,color-mix(in srgb,var(--sl-color-bg) 54%,transparent) 38%,transparent 70%); pointer-events:none; }
  .blade-field__content { box-sizing:border-box; max-width:76rem; padding:clamp(4rem,9vw,8rem) clamp(1.35rem,6vw,5rem); position:relative; width:100%; z-index:1; }
  .blade-field__eyebrow { align-items:center; color:var(--sl-color-gray-2); display:flex; font-family:var(--sl-font-mono); font-size:.66rem; font-weight:800; gap:.55rem; letter-spacing:.16em; margin:0 0 1.25rem; text-transform:uppercase; }
  .blade-field__eyebrow span { background:var(--tear-cyan); display:block; height:.6rem; width:.6rem; }
  h1 { color:var(--sl-color-white); font-family:var(--sl-font-mono); font-size:clamp(3.25rem,10vw,8.5rem); letter-spacing:-.09em; line-height:.74; margin:0; max-width:7ch; }
  h1 small,h1 strong { display:block; font:inherit; } h1 small { color:var(--sl-color-gray-3); font-size:.36em; letter-spacing:.24em; margin-left:.18em; margin-bottom:.35rem; } h1 strong { color:var(--sl-color-white); letter-spacing:.02em; }
  .blade-field__lede { color:var(--sl-color-gray-2); font-family:var(--sl-font); font-size:clamp(.9rem,1.5vw,1.05rem); line-height:1.7; margin:2rem 0; max-width:48ch; text-transform:none; }
  .blade-field__actions { display:flex; flex-wrap:wrap; gap:.65rem; }
  .blade-field__actions a { font-family:var(--sl-font-mono); font-size:.7rem; font-weight:800; letter-spacing:.1em; padding:.82rem 1rem; text-decoration:none; text-transform:uppercase; }
  .blade-field__primary { background:var(--sl-color-white); color:var(--sl-color-black); } .blade-field__primary span { color:var(--tear-cyan); font-size:1.15em; margin-left:.35rem; }
  .blade-field__secondary { border:1px solid var(--sl-color-hairline); color:var(--sl-color-white); background:color-mix(in srgb,var(--sl-color-bg) 56%,transparent); }
  .blade-field__actions a:hover,.blade-field__actions a:focus-visible { outline:2px solid var(--tear-cyan); outline-offset:3px; }
  .blade-field__legend { display:flex; gap:1.25rem; margin:4.5rem 0 0; } .blade-field__legend div { border-left:1px solid var(--sl-color-hairline); padding-left:.55rem; } .blade-field__legend dt { font-size:.61rem; font-weight:800; letter-spacing:.08em; } .blade-field__legend dd { color:var(--sl-color-gray-2); font-size:.58rem; letter-spacing:.12em; margin:.15rem 0 0; text-transform:uppercase; } .red{color:var(--tear-red)} .cyan{color:var(--tear-cyan)} .violet{color:var(--tear-purple)}
  @media (max-width:700px) { .blade-field { min-height:620px; align-items:start; } .blade-field__image { object-position:62% center; } .blade-field__scrim { background:linear-gradient(180deg,color-mix(in srgb,var(--sl-color-bg) 92%,transparent) 0%,color-mix(in srgb,var(--sl-color-bg) 72%,transparent) 55%,transparent 100%); } .blade-field__content { padding-top:4.5rem; } .blade-field__legend { margin-top:3.25rem; } }
  @media (prefers-reduced-motion:no-preference) { .blade-field__content { animation:field-enter .6s cubic-bezier(.16,1,.3,1) both; } } @keyframes field-enter { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
</style>
