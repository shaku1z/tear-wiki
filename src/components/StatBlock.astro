---
// StatBlock.astro
// Renders a structured stat table for an enemy or boss.
// Usage: <StatBlock name="Charger" color="#e23b3b" hp={220} hpMax={300} stats={...} notes="..." />

interface Props {
  name: string;
  color: string;        // hex accent for the enemy type (from CONFIG.colors)
  variant?: string;     // optional sub-name / affix
  hp?: number;          // actual HP value (shown as animated bar)
  hpMax?: number;       // reference HP for bar percentage (default: same as hp)
  stats: Record<string, string | number>;
  notes?: string;
}

const { name, color, variant, hp, hpMax, stats, notes } = Astro.props;
const hpPct = hp != null ? Math.round((hp / (hpMax ?? hp)) * 100) : null;
---

<div class="tear-stat-block" style={`--stat-accent: ${color}`}>
  <div class="tear-stat-block-header">
    <span class="tear-stat-accent-dot" aria-hidden="true"></span>
    <span class="tear-stat-block-name">{name}</span>
    {variant && <span style="margin-left:auto;font-size:0.68rem;letter-spacing:0.08em;text-transform:uppercase;opacity:0.6">{variant}</span>}
  </div>

  {hpPct != null && (
    <div class="tear-hp-bar-wrap" title={`HP: ${hp}`}>
      <div class="tear-hp-bar-track">
        <div class="tear-hp-bar-fill" data-hp={hpPct}></div>
      </div>
    </div>
  )}

  <div class="tear-stat-rows">
    {Object.entries(stats).map(([k, v]) => (
      <div class="tear-stat-row">
        <span class="tear-stat-label">{k}</span>
        <span class="tear-stat-value">{v}</span>
      </div>
    ))}
  </div>

  {notes && <p class="tear-stat-notes">{notes}</p>}
</div>

<style>
.tear-stat-notes {
  padding: 0.6rem 0.85rem 0.75rem;
  font-size: 0.82rem;
  color: var(--sl-color-gray-2);
  border-top: 1px solid var(--sl-color-hairline);
  margin: 0 !important;
  font-style: italic;
}
</style>
