---
import gameManifest from '../data/game-manifest.json';
const trick = gameManifest.config.trick;
---

<section class="style-readout"><header><span>STYLE METER / LIVE THRESHOLDS</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header><div class="tiers">{trick.tiers.slice(1).map((tier) => <div><span>{tier.name}</span><b>{tier.at} PTS</b><em>{tier.mult}×</em></div>)}</div><footer><span>DRAIN {trick.drainRate}/S</span><span>HIT LOSS {Math.round(trick.hitLoss * 100)}%</span><span>DECAY {trick.decay}</span></footer></section>

<style>
  .style-readout { border: 1px solid var(--sl-color-hairline); font-family: var(--sl-font-mono); margin: 1.5rem 0; } header, footer { background: var(--sl-color-gray-6); color: var(--sl-color-gray-3); display: flex; font-size: .65rem; font-weight: 800; gap: 1rem; justify-content: space-between; letter-spacing: .1em; padding: .65rem .75rem; text-transform: uppercase; } header { border-bottom: 1px solid var(--sl-color-hairline); } footer { border-top: 1px solid var(--sl-color-hairline); justify-content: flex-start; } header > *, footer > * { margin: 0; } code { color: var(--tear-cyan); font: inherit; } .tiers { align-items: stretch; display: grid; grid-template-columns: repeat(5, 1fr); } .tiers > div { border-right: 1px solid var(--sl-color-hairline); margin: 0; min-width: 0; padding: .75rem; } .tiers div:last-child { border-right: 0; } .tiers span, .tiers b, .tiers em { display: block; } .tiers span { color: var(--sl-color-white); font-size: .72rem; } .tiers b { color: var(--tear-cyan); font-size: .95rem; margin-top: .35rem; } .tiers em { color: var(--sl-color-gray-3); font-size: .65rem; font-style: normal; margin-top: .2rem; } @media (max-width: 680px) { .tiers { grid-template-columns: 1fr 1fr; } .tiers div { border-bottom: 1px solid var(--sl-color-hairline); } footer { flex-wrap: wrap; } }
</style>
