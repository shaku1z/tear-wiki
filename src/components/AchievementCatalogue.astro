---
import gameManifest from '../data/game-manifest.json';
const achievements = gameManifest.achievements;
const rarity = achievements.RARITY;
const categories = achievements.CATS;
---
<section class="achievement-catalogue"><header><span>ACHIEVEMENT ARCHIVE</span><code>{gameManifest.source.commit.slice(0, 7)}</code></header><div class="rarity">{Object.entries(rarity).map(([id, item]) => <span style={`--rarity:${item.color}`}>{item.name} <b>{item.shards} SHARDS</b></span>)}</div>{Object.entries(categories).map(([id, cat]) => <div class="category" style={`--category:${cat.color}`}><h2>{cat.name}</h2><div class="cards">{achievements.list.filter((item) => item.cat === id).map((item) => <article><span style={`color:${rarity[item.rarity].color}`}>{rarity[item.rarity].name}</span><h3>{item.name}</h3><p>{item.desc}</p><b>{item.master ? 'MASTER' : `${item.goal} TARGET`} / {rarity[item.rarity].shards} SHARDS</b></article>)}</div></div>)}</section>
<style>.achievement-catalogue{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.rarity{display:flex;flex-wrap:wrap;border-bottom:1px solid var(--sl-color-hairline)}.rarity span{border-right:1px solid var(--sl-color-hairline);color:var(--rarity);font-size:.65rem;padding:.55rem .7rem}.rarity b{color:var(--sl-color-gray-3);margin-left:.35rem}.category{border-bottom:1px solid var(--sl-color-hairline);padding:1rem}.category:last-child{border-bottom:0}.category h2{border-left:4px solid var(--category);border-bottom:0;font-size:.9rem;margin:0 0 .7rem;padding:.15rem 0 .15rem .55rem}.cards{align-items:stretch;display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:.5rem}.cards article{border:1px solid var(--sl-color-hairline);margin:0;padding:.7rem}.cards span,.cards>b{font-size:.6rem;font-weight:800;letter-spacing:.06em}.cards h3{border:0;font-size:.8rem;margin:.4rem 0;padding:0}.cards p{color:var(--sl-color-gray-3);font-family:var(--sl-font);font-size:.73rem;line-height:1.4;margin:0 0 .65rem}.cards>b{color:var(--sl-color-gray-2)}</style>
