---
import gameManifest from '../data/game-manifest.json';
const labels = { kills:'ENEMIES', parries:'PERFECT PARRIES', boss:'BOSSES', nohit:'NO-HIT WAVES', wave:'WAVE REACHED', superslam:'POWER SLAMS', updraft:'UPDRAFTS', runs:'RUNS', deflect:'DEFLECTS', air:'AIR HITS' };
---
<section class="daily-console"><header><span>DAILY BOUNTY POOL</span><code>{gameManifest.source.commit.slice(0,7)}</code></header><div>{gameManifest.dailyChallenges.map((challenge)=><article><span>{labels[challenge.key] || challenge.key}</span><b>{challenge.goal}</b><em>{challenge.mode.toUpperCase()} / {challenge.shards} SHARDS</em></article>)}</div></section>
<style>.daily-console{border:1px solid var(--sl-color-hairline);font-family:var(--sl-font-mono);margin:1.5rem 0}header{background:var(--sl-color-gray-6);border-bottom:1px solid var(--sl-color-hairline);color:var(--sl-color-gray-3);display:flex;font-size:.65rem;font-weight:800;justify-content:space-between;letter-spacing:.1em;padding:.65rem .75rem;text-transform:uppercase}code{color:var(--tear-cyan);font:inherit}.daily-console>div{align-items:stretch;display:grid;grid-template-columns:repeat(auto-fit,minmax(145px,1fr))}.daily-console article{border-bottom:1px solid var(--sl-color-hairline);border-right:1px solid var(--sl-color-hairline);margin:0;padding:.7rem}.daily-console span,.daily-console b,.daily-console em{display:block}.daily-console span{color:var(--sl-color-gray-3);font-size:.62rem}.daily-console b{font-size:1.2rem;margin:.3rem 0}.daily-console em{color:var(--tear-cyan);font-size:.6rem;font-style:normal;font-weight:800;letter-spacing:.06em}</style>
