---
// Difficulty values are generated from the synchronized game configuration.
import gameManifest from '../data/game-manifest.json';

const difficulties = gameManifest.config.difficulties || [];
const formatModifier = (value) => value === 1 ? '—' : `${value > 1 ? '+' : ''}${Math.round((value - 1) * 100)}%`;
const tone = (value) => value === 1 ? '' : value > 1 ? 'positive' : 'negative';
---

<div class="difficulty-console">
  <div class="console-header"><span>DIFFICULTY PROTOCOLS</span><code>{gameManifest.source.commit.slice(0, 7)}</code></div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Protocol</th><th>Enemy HP</th><th>Damage</th><th>Count</th><th>Coins</th><th>Score</th><th>Condition</th></tr></thead>
      <tbody>
        {difficulties.map((difficulty) => (
          <tr>
            <td><b>{difficulty.label}</b><span>{difficulty.desc}</span></td>
            <td class={tone(difficulty.mods.hp)}>{formatModifier(difficulty.mods.hp)}</td>
            <td class={tone(difficulty.mods.dmg)}>{formatModifier(difficulty.mods.dmg)}</td>
            <td class={tone(difficulty.mods.count)}>{formatModifier(difficulty.mods.count)}</td>
            <td class={tone(difficulty.mods.coin)}>{formatModifier(difficulty.mods.coin)}</td>
            <td class={tone(difficulty.mods.score)}>{formatModifier(difficulty.mods.score)}</td>
            <td>{difficulty.oneHit ? 'ONE HIT' : '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .difficulty-console { border: 1px solid var(--sl-color-hairline); font-family: var(--sl-font-mono); margin: 1.5rem 0; }
  .console-header { border-bottom: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-3); display: flex; font-size: .66rem; font-weight: 800; justify-content: space-between; letter-spacing: .1em; padding: .65rem .75rem; text-transform: uppercase; }
  .console-header code { color: var(--tear-cyan); font: inherit; }
  .table-wrap { overflow-x: auto; }
  table { border-collapse: collapse; font-size: .78rem; min-width: 680px; width: 100%; }
  th { background: var(--sl-color-gray-6); color: var(--sl-color-gray-3); font-size: .62rem; letter-spacing: .08em; padding: .65rem; text-align: left; text-transform: uppercase; }
  td { border-top: 1px solid var(--sl-color-hairline); color: var(--sl-color-gray-2); font-variant-numeric: tabular-nums; padding: .7rem .65rem; text-align: center; }
  td:first-child { text-align: left; } td:first-child b { color: var(--sl-color-white); display: block; text-transform: uppercase; } td:first-child span { color: var(--sl-color-gray-3); display: block; font-family: var(--sl-font); font-size: .74rem; margin-top: .2rem; }
  .positive { color: var(--tear-green); font-weight: 800; } .negative { color: var(--tear-red); font-weight: 800; }
</style>
