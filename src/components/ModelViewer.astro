---
import gameManifest from '../data/game-manifest.json';
import { BOSS_MODELS, getModelProfile } from '../scripts/model-viewer-data.js';

export interface Props {
  model: 'charger' | 'ranged' | 'flyer' | 'bomber' | 'armored' | 'support' | 'chimera' | 'wraith' | 'aldric' | 'iron-colossus' | 'the-echo' | 'the-source' | 'warden';
  variant?: string;
}
const { model, variant } = Astro.props;
const profile = getModelProfile(model);
const isBoss = BOSS_MODELS.has(model);
const accentKey = model === 'iron-colossus' ? 'boss' : model === 'the-echo' ? 'boss' : model === 'the-source' ? 'boss' : model === 'aldric' || model === 'warden' ? 'boss' : model === 'support' ? 'priest' : model;
const accent = gameManifest.config.colors?.[accentKey] || gameManifest.config.colors?.enemyShot || '#13c4d6';
const displayName = model.replaceAll('-', ' ').replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<tear-model-viewer
  data-model={model}
  data-variant={variant || ''}
  data-motif={profile.motif}
  class="tear-model-viewer"
  style={`--viewer-accent:${accent}`}
  tabindex="0"
  aria-label={`${displayName} combat archive`}
>
  <section class="archive-shell">
    <header class="archive-heading">
      <div class="archive-index" aria-hidden="true"><i></i><span>TACTICAL ARCHIVE</span></div>
      <div class="archive-identity">
        <p>{isBoss ? 'BOSS RECORD' : 'ENEMY FAMILY'} / {profile.role.toUpperCase()}</p>
        <h2>{displayName}</h2>
      </div>
      <div class="archive-provenance" title="Generated from the live game repository">
        <span>LIVE MODEL</span><code>{gameManifest.source.commit.slice(0, 7)}</code>
      </div>
    </header>

    <div class="model-stage">
      <div class="arena-atmosphere" aria-hidden="true"><i></i><i></i><i></i></div>
      <div class="arena-measurements" aria-hidden="true"><span>00</span><span>01</span><span>02</span><span>03</span></div>
      <div class="arena-ground" aria-hidden="true"></div>
      <div class="model-fallback" role="status"><span>RECONSTRUCTING</span><b>{displayName}</b></div>
      <canvas aria-label={`Live game reconstruction of ${displayName}`}></canvas>
      <div class="model-error" hidden><b>RECONSTRUCTION FAILED</b><span>The tactical record remains available below.</span></div>
      <div class="stage-readout" aria-live="polite">
        <span class="model-state">EXHIBIT / RUNNING</span>
        <span>{profile.range.toUpperCase()} RANGE</span>
      </div>
      <div class="corner-mark corner-a" aria-hidden="true"></div>
      <div class="corner-mark corner-b" aria-hidden="true"></div>
    </div>

    <footer class="command-rail">
      <div class="control-group time-controls" role="group" aria-label="Playback speed">
        <span class="control-label">SPEED</span>
        <button class="ctrl-btn" type="button" data-time="0.25">¼</button>
        <button class="ctrl-btn" type="button" data-time="0.5">½</button>
        <button class="ctrl-btn active" type="button" data-time="1" aria-pressed="true">1×</button>
      </div>
      {isBoss && (
        <div class="control-group phase-controls" role="group" aria-label="Boss phase">
          <span class="control-label">PHASE</span>
          <button class="ctrl-btn active" type="button" data-phase="auto" aria-pressed="true">AUTO</button>
          <button class="ctrl-btn" type="button" data-phase="1">I</button>
          <button class="ctrl-btn" type="button" data-phase="2">II</button>
          <button class="ctrl-btn" type="button" data-phase="3">III</button>
        </div>
      )}
      <label class="zoom-control"><span>FRAME</span><input type="range" class="zoom-slider" min="0" max="1" step="0.01" value="0.3125" aria-label="Model framing" /></label>
      <button class="analysis-toggle rail-action" type="button" aria-pressed="false">ANALYSIS</button>
      <button class="reset-btn rail-action" type="button">RESET</button>
    </footer>
  </section>
</tear-model-viewer>

<script>
  import { initModelViewer } from '../scripts/model-renderer.js';

  class TearModelViewer extends HTMLElement {
    cleanup = null;
    connectedCallback() {
      if (this.dataset.connected === 'true') return;
      this.dataset.connected = 'true';
      const canvas = this.querySelector('canvas');
      const modelName = this.dataset.model;
      const state = { timeScale: 1, phase: 'auto', debug: false, camScale: 1, playing: true, mode: 'exhibit' };
      this.viewerState = state;

      if (canvas && modelName) {
        try {
          canvas.addEventListener('modelready', () => this.classList.add('is-ready'), { once: true });
          this.cleanup = initModelViewer(canvas, modelName, this.dataset.variant, state);
        } catch (error) {
          this.classList.add('has-error');
          this.dataset.error = error instanceof Error ? error.message : String(error);
          this.querySelector('.model-error')?.removeAttribute('hidden');
          console.error(`Unable to initialize ${modelName} model viewer`, error);
        }
      }

      this.querySelectorAll('.time-controls .ctrl-btn').forEach((button) => button.addEventListener('click', () => {
        this.selectButton('.time-controls .ctrl-btn', button);
        state.timeScale = Number(button.dataset.time);
      }));
      this.querySelectorAll('.phase-controls .ctrl-btn').forEach((button) => button.addEventListener('click', () => {
        this.selectButton('.phase-controls .ctrl-btn', button);
        state.phase = button.dataset.phase;
      }));
      this.querySelector('.analysis-toggle')?.addEventListener('click', (event) => {
        state.debug = !state.debug;
        event.currentTarget.setAttribute('aria-pressed', String(state.debug));
        event.currentTarget.classList.toggle('active', state.debug);
      });
      this.querySelector('.reset-btn')?.addEventListener('click', () => this.cleanup?.reset());
      this.querySelector('.zoom-slider')?.addEventListener('input', (event) => {
        state.camScale = 0.75 + Number(event.currentTarget.value) * 0.8;
      });
    }
    selectButton(selector, selected) {
      this.querySelectorAll(selector).forEach((button) => {
        const active = button === selected;
        button.classList.toggle('active', active);
        button.setAttribute('aria-pressed', String(active));
      });
    }
    disconnectedCallback() {
      this.cleanup?.destroy();
      this.cleanup = null;
      delete this.dataset.connected;
    }
  }
  if (!customElements.get('tear-model-viewer')) customElements.define('tear-model-viewer', TearModelViewer);
</script>

<style>
  .tear-model-viewer {
    --viewer-surface: #0a0b0e;
    --viewer-surface-raised: #111318;
    --viewer-ink: #f5f7f8;
    --viewer-muted: #858a92;
    --viewer-line: rgba(245, 247, 248, .16);
    --viewer-grid: rgba(245, 247, 248, .055);
    --viewer-glow: color-mix(in srgb, var(--viewer-accent) 20%, transparent);
    --viewer-shadow: rgba(0, 0, 0, .48);
    display: block;
    margin: 2.5rem 0 3rem;
    color: var(--viewer-ink);
    outline: none;
  }
  .tear-model-viewer:focus-visible .archive-shell { outline: 2px solid var(--viewer-accent); outline-offset: 4px; }
  .archive-shell { border: 1px solid var(--viewer-line); background: var(--viewer-surface); box-shadow: 0 24px 60px var(--viewer-shadow); clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 22px 100%, 0 calc(100% - 22px)); }
  .archive-heading { min-height: 96px; display: grid; grid-template-columns: minmax(120px, .7fr) 1.4fr auto; align-items: stretch; border-bottom: 1px solid var(--viewer-line); }
  .archive-index, .archive-provenance { padding: 1rem 1.25rem; display: flex; align-items: center; gap: .65rem; font: 700 .62rem/1 var(--sl-font-mono); letter-spacing: .15em; color: var(--viewer-muted); }
  .archive-index { border-right: 1px solid var(--viewer-line); }
  .archive-index i { width: 24px; height: 2px; background: var(--viewer-accent); box-shadow: 8px 0 16px var(--viewer-accent); }
  .archive-identity { padding: 1rem 1.4rem; align-self: center; }
  .archive-identity p { margin: 0 0 .35rem; color: var(--viewer-accent); font: 700 .64rem/1 var(--sl-font-mono); letter-spacing: .17em; }
  .archive-identity h2 { margin: 0; color: var(--viewer-ink); font: 800 clamp(1.3rem, 3vw, 2rem)/1 var(--sl-font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .archive-provenance { justify-content: flex-end; border-left: 1px solid var(--viewer-line); flex-wrap: wrap; max-width: 170px; }
  .archive-provenance span::before { content: ''; display: inline-block; width: 6px; height: 6px; margin-right: .5rem; background: #1faf5a; box-shadow: 0 0 10px #1faf5a; }
  .archive-provenance code { color: var(--viewer-ink); background: none; padding: 0; }
  .model-stage { position: relative; height: clamp(330px, 52vw, 520px); overflow: hidden; background: radial-gradient(circle at 50% 46%, var(--viewer-glow), transparent 36%), var(--viewer-surface); isolation: isolate; }
  .model-stage canvas { position: absolute; inset: 0; z-index: 4; width: 100%; height: 100%; display: block; filter: drop-shadow(0 16px 13px var(--viewer-shadow)); }
  .arena-atmosphere { position: absolute; inset: 0; z-index: 1; background-image: linear-gradient(var(--viewer-grid) 1px, transparent 1px), linear-gradient(90deg, var(--viewer-grid) 1px, transparent 1px); background-size: 36px 36px; mask-image: linear-gradient(to bottom, transparent, #000 20%, #000 75%, transparent); }
  .arena-atmosphere i { position: absolute; background: var(--viewer-accent); opacity: .16; }
  .arena-atmosphere i:nth-child(1) { width: 1px; height: 48%; left: 22%; top: 26%; }
  .arena-atmosphere i:nth-child(2) { height: 1px; width: 42%; left: 44%; top: 31%; }
  .arena-atmosphere i:nth-child(3) { width: 9rem; height: 9rem; border: 1px solid var(--viewer-accent); background: transparent; border-radius: 50%; left: calc(50% - 4.5rem); top: calc(50% - 4.5rem); opacity: .09; }
  [data-motif='blast'] .arena-atmosphere i:nth-child(3), [data-motif='sight'] .arena-atmosphere i:nth-child(3) { opacity: .22; }
  [data-motif='rush'] .arena-atmosphere { transform: skewX(-7deg); }
  .arena-measurements { position: absolute; z-index: 2; inset: 1rem auto 1rem 1rem; display: flex; flex-direction: column; justify-content: space-between; color: var(--viewer-muted); opacity: .45; font: 600 .55rem/1 var(--sl-font-mono); }
  .arena-ground { position: absolute; z-index: 2; left: 8%; right: 8%; bottom: 18%; height: 1px; background: linear-gradient(90deg, transparent, var(--viewer-line) 15%, var(--viewer-accent) 50%, var(--viewer-line) 85%, transparent); box-shadow: 0 18px 40px var(--viewer-glow); }
  .stage-readout { position: absolute; z-index: 7; inset: auto 1.25rem 1rem; display: flex; justify-content: space-between; color: var(--viewer-muted); font: 700 .58rem/1 var(--sl-font-mono); letter-spacing: .14em; pointer-events: none; }
  .model-state { color: var(--viewer-accent); }
  .corner-mark { position: absolute; z-index: 7; width: 22px; height: 22px; pointer-events: none; }
  .corner-a { top: 14px; left: 14px; border-top: 1px solid var(--viewer-accent); border-left: 1px solid var(--viewer-accent); }
  .corner-b { right: 14px; bottom: 14px; border-right: 1px solid var(--viewer-accent); border-bottom: 1px solid var(--viewer-accent); }
  .model-fallback, .model-error { position: absolute; inset: 0; z-index: 3; display: grid; place-content: center; gap: .45rem; text-align: center; font-family: var(--sl-font-mono); letter-spacing: .16em; color: var(--viewer-muted); }
  .model-fallback::before { content: ''; width: 1px; height: 90px; margin: auto; background: linear-gradient(transparent, var(--viewer-accent), transparent); animation: reconstruct 1.1s ease-in-out infinite; }
  .model-fallback b { color: var(--viewer-ink); font-size: 1.35rem; }
  .is-ready .model-fallback { opacity: 0; pointer-events: none; transition: opacity .25s ease; }
  .model-error { z-index: 10; background: var(--viewer-surface); color: var(--viewer-ink); }
  .model-error[hidden] { display: none; }
  .command-rail { min-height: 62px; padding: .65rem .8rem; display: flex; align-items: stretch; gap: .5rem; border-top: 1px solid var(--viewer-line); background: var(--viewer-surface-raised); overflow-x: auto; }
  .control-group, .zoom-control { display: flex; align-items: center; gap: .2rem; padding-right: .5rem; border-right: 1px solid var(--viewer-line); white-space: nowrap; }
  .control-label, .zoom-control span { padding: 0 .55rem; color: var(--viewer-muted); font: 700 .58rem/1 var(--sl-font-mono); letter-spacing: .14em; }
  .ctrl-btn, .rail-action { min-width: 38px; height: 40px; border: 1px solid transparent; border-radius: 0; background: transparent; color: var(--viewer-muted); font: 700 .68rem/1 var(--sl-font-mono); letter-spacing: .08em; cursor: pointer; }
  .ctrl-btn:hover, .rail-action:hover { color: var(--viewer-ink); border-color: var(--viewer-line); }
  .ctrl-btn:focus-visible, .rail-action:focus-visible, .zoom-slider:focus-visible { outline: 2px solid var(--viewer-accent); outline-offset: -2px; }
  .ctrl-btn.active, .rail-action.active { color: var(--viewer-surface); background: var(--viewer-accent); border-color: var(--viewer-accent); }
  .zoom-control { flex: 1; min-width: 150px; }
  .zoom-slider { width: 100%; min-width: 80px; accent-color: var(--viewer-accent); cursor: ew-resize; }
  .rail-action { padding: 0 .9rem; min-width: max-content; }
  @keyframes reconstruct { 0%, 100% { transform: scaleY(.35); opacity: .35; } 50% { transform: scaleY(1); opacity: 1; } }

  :global([data-theme='light']) .tear-model-viewer {
    --viewer-surface: #f3f5f7;
    --viewer-surface-raised: #e8ecef;
    --viewer-ink: #111419;
    --viewer-muted: #636a73;
    --viewer-line: rgba(17, 20, 25, .2);
    --viewer-grid: rgba(17, 20, 25, .07);
    --viewer-glow: color-mix(in srgb, var(--viewer-accent) 13%, transparent);
    --viewer-shadow: rgba(30, 42, 55, .18);
  }
  @media (max-width: 640px) {
    .archive-heading { grid-template-columns: 1fr auto; min-height: 82px; }
    .archive-index { display: none; }
    .archive-identity { padding: .9rem 1rem; }
    .archive-provenance { max-width: 120px; padding: .75rem; }
    .archive-provenance span { display: none; }
    .model-stage { height: clamp(300px, 82vw, 410px); }
    .stage-readout { inset-inline: .8rem; }
    .command-rail { scroll-snap-type: x proximity; }
    .control-group, .zoom-control, .rail-action { scroll-snap-align: start; }
  }
  @media (prefers-reduced-motion: reduce) {
    .model-fallback::before { animation: none; }
    .is-ready .model-fallback { transition: none; }
  }
</style>
